{
  "runtimes": [
    {
      "name": "Codex Cloud",
      "status": "available-locally",
      "role": "async branch worker",
      "manualSetup": ["choose environment id", "provision environment secrets"]
    },
    {
      "name": "GitHub Codespaces",
      "status": "repo-ready",
      "role": "interactive cloud workspace",
      "manualSetup": ["create codespace", "authenticate Codex CLI", "authenticate Claude Code CLI", "add secrets"]
    },
    {
      "name": "VPS/cloud workstation",
      "status": "documented-not-provisioned",
